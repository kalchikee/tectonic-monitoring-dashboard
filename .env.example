# Copy this file to .env and fill in values

# Database (PostgreSQL + PostGIS)
POSTGRES_PASSWORD=changeme_secure_password
DATABASE_URL=postgresql://tectonic:changeme_secure_password@db:5432/tectonic_monitor

# API settings
API_BASE_URL=http://localhost:8000

# Pipeline settings
PIPELINE_LOOKBACK_HOURS=25
PIPELINE_MIN_MAGNITUDE=1.0
PIPELINE_SCHEDULE_HOUR=0   # Hour of day for daily update (UTC)
